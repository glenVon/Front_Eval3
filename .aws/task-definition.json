{
  "family": "task-front",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::539241557920:role/LabRole",
  "taskRoleArn": "arn:aws:iam::539241557920:role/LabRole",
  "containerDefinitions": [
    {
      "name": "container-front",
      "image": "539241557920.dkr.ecr.us-east-1.amazonaws.com/front-eval3:latest",
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80
        }
      ],
      "essential": true,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/eval3-cluster-logs",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "frontend"
        }
      }
    }
  ]
}